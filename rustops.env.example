# Shared API settings
RUSTOPS_API_BASE_URL=http://127.0.0.1:2077
RUSTMGR_API_KEY=replace-me

# API host/runtime settings
RUSTMGR_BIND=http://0.0.0.0:2077
RUSTMGR_PATH=/opt/rust-manager/rustmgr.sh
RUSTMGR_RUNTIME=/opt/rust-manager/runtime
RUSTMGR_CONFIG=/opt/rust-manager/config
RUSTMGR_TASKS_DIR=/opt/rust-manager/tasks

# Debian remote-host agent. Use a dedicated token when this machine is managed
# by another RusticalandOPS API over the network.
RUSTOPS_REMOTE_AGENT_BIND=http://0.0.0.0:2088
RUSTOPS_REMOTE_AGENT_API_KEY=replace-me-remote-agent

# Agent LLM settings
RUSTOPS_LLM_PROVIDER=lmstudio
RUSTOPS_LLM_ENABLED=true
RUSTOPS_LLM_BASE_URL=http://127.0.0.1:1234
RUSTOPS_LLM_MODEL=llmster
RUSTOPS_LLM_API_KEY=
RUSTOPS_LLM_HTTP_REFERER=http://localhost
RUSTOPS_LLM_APP_TITLE=RustOpsAgent
RUSTOPS_LLM_USE_FOR_RECOMMENDATIONS=true
RUSTOPS_LLM_REQUEST_STRATEGY=fallback
RUSTOPS_LLM_SECONDARY_ENABLED=false
RUSTOPS_LLM_SECONDARY_BASE_URL=
RUSTOPS_LLM_SECONDARY_MODEL=
RUSTOPS_LLM_SECONDARY_API_KEY=
RUSTOPS_LLM_SECONDARY_HTTP_REFERER=
RUSTOPS_LLM_SECONDARY_APP_TITLE=
RUSTOPS_LLM_USE_CHAT_SYSTEM_PROMPT=false

# Shared Sentry settings
RUSTOPS_SENTRY_DSN=
RUSTOPS_SENTRY_ENVIRONMENT=production
RUSTOPS_SENTRY_RELEASE=
RUSTOPS_SENTRY_DEBUG=false
RUSTOPS_SENTRY_TRACES_SAMPLE_RATE=0.1
RUSTOPS_SENTRY_MAX_BREADCRUMBS=100

# Shared agent paths
RUSTOPS_AGENT_STATE_PATH=/opt/rust-manager/agent/RustOpsAgent/data/agent-state.json
RUSTOPS_AGENT_NEOCORTEX_ROOT=/opt/rust-manager/agent/RustOpsAgent/data/NeoCortex
RUSTOPS_MEMORY_PROVIDER=sqlite
RUSTOPS_MEMORY_DATABASE_PATH=/opt/rust-manager/agent/RustOpsAgent/data/semantic-memory.db
RUSTOPS_MEMORY_SEARCH_ENABLED=true
RUSTOPS_MEMORY_WRITE_ENABLED=true
RUSTOPS_MEMORY_DEBUG_LOGGING_ENABLED=false
RUSTOPS_MEMORY_SIMILARITY_THRESHOLD=0.62
RUSTOPS_MEMORY_MAX_RETRIEVED_PER_STEP=6
RUSTOPS_MEMORY_MAX_SEARCH_CANDIDATES=400
RUSTOPS_MEMORY_MAX_INJECTED_CHARACTERS=2200
RUSTOPS_MEMORY_MAX_WRITES_PER_STEP=1
RUSTOPS_MEMORY_PRUNE_LOW_IMPORTANCE_THRESHOLD=0.15
RUSTOPS_MEMORY_PRUNE_LOW_CONFIDENCE_THRESHOLD=0.2
RUSTOPS_MEMORY_PRUNE_OLDER_THAN_DAYS=30
RUSTOPS_EMBEDDING_PROVIDER=openai-compatible
RUSTOPS_EMBEDDING_BASE_URL=http://127.0.0.1:1234/v1
RUSTOPS_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
RUSTOPS_EMBEDDING_API_KEY=
RUSTOPS_EMBEDDING_API_KEY_ENV_VAR=RUSTOPS_EMBEDDING_API_KEY
RUSTOPS_EMBEDDING_REQUIRE_API_KEY=false
RUSTOPS_EMBEDDING_TIMEOUT_SECONDS=30
RUSTOPS_EMBEDDING_BATCH_SIZE=8
RUSTOPS_FEEDBACK_INBOX_PATH=/opt/rust-manager/agent/RustOpsAgent/data/feedback-inbox
RUSTOPS_DECISION_INBOX_PATH=/opt/rust-manager/agent/RustOpsAgent/data/decision-inbox
RUSTOPS_CHAT_INBOX_PATH=/opt/rust-manager/agent/RustOpsAgent/data/chat-inbox
RUSTOPS_MESSAGE_OUTBOX_PATH=/opt/rust-manager/agent/RustOpsAgent/data/message-outbox
RUSTOPS_MESSAGE_OUTBOX_SENT_PATH=/opt/rust-manager/agent/RustOpsAgent/data/message-outbox-sent

# Agent self-repair settings
RUSTOPS_SELF_REPAIR_ENABLED=true
RUSTOPS_SELF_REPAIR_INTERVAL_SECONDS=180
RUSTOPS_SELF_REPAIR_MAX_ACTIONS=4
RUSTOPS_SELF_REPAIR_MAX_FILE_BYTES=32768
RUSTOPS_SELF_REPAIR_SCOPE_ROOT=/opt/rust-manager
RUSTOPS_SELF_REPAIR_WORKSPACE_PATH=/opt/rust-manager/agent/RustOpsAgent/data/self-repair
RUSTOPS_SELF_REPAIR_SOURCE_ROOT=/opt/rust-manager/src
RUSTOPS_SELF_REPAIR_BUILD_OUTPUT=/opt/rust-manager
RUSTOPS_SELF_REPAIR_ALLOW_SCOPE_WRITES=true
RUSTOPS_SELF_REPAIR_APPLY_LOG_RULES=true
RUSTOPS_SELF_REPAIR_APPLY_REPLY_STYLE=true
RUSTOPS_SELF_REPAIR_ALLOW_SOURCE_BUILDS=true
RUSTOPS_SELF_REPAIR_ALLOW_SERVICE_RESTARTS=true
RUSTOPS_SELF_REPAIR_NOTIFY_ADMINS=false

# Agent git ops settings
RUSTOPS_GITOPS_ENABLED=false
RUSTOPS_GITOPS_REPO_PATH=/opt/rust-manager/src
RUSTOPS_GITOPS_REMOTE=origin
RUSTOPS_GITOPS_BASE_BRANCH=main
RUSTOPS_GITOPS_PUSH_BRANCH_PREFIX=agent/
RUSTOPS_GITOPS_ALLOW_PUSH=false
RUSTOPS_GITOPS_ALLOW_MANUAL_PULL_REBUILD=true
RUSTOPS_GITOPS_AUTO_PULL_ENABLED=false
RUSTOPS_GITOPS_AUTO_PULL_INTERVAL_MINUTES=15
RUSTOPS_GITOPS_AUTO_PULL_REBUILD=true
RUSTOPS_GITOPS_AUTO_RESTART_AFTER_PULL_REBUILD=false
RUSTOPS_GITOPS_REQUIRE_CLEAN_WORKTREE_FOR_PULL=true

# Agent server-command policy
RUSTOPS_COMMANDS_ENABLED=true
RUSTOPS_COMMANDS_FREE_MODE=false
RUSTOPS_COMMANDS_DEFAULT_WAIT_MS=2500
RUSTOPS_COMMANDS_MAX_WAIT_MS=12000
RUSTOPS_COMMANDS_MAX_OUTPUT_CHARS=8000
RUSTOPS_COMMANDS_ALLOWLIST=playerlist,serverinfo,bans,oxide.plugins,status,version

# Agent plugin update monitor
RUSTOPS_PLUGIN_UPDATES_ENABLED=true
RUSTOPS_PLUGIN_UPDATES_INTERVAL_MINUTES=60
RUSTOPS_PLUGIN_UPDATES_NOTIFY_ADMINS=true
RUSTOPS_PLUGIN_UPDATES_SEARCH_URL=https://umod.org/plugins/search.json?query={0}&page=1&sort=title&sortdir=asc&filter={1}
RUSTOPS_PLUGIN_UPDATES_FILTER=rust

# Legacy command policy overrides (kept for backward compatibility)
RUSTOPS_ALLOW_ANY_SERVER_COMMAND=false
RUSTOPS_ALLOWED_SERVER_COMMAND_PREFIXES=oxide.,o.,status,version,plugins,global.,serverinfo

# Steam bot settings
RUSTOPS_STEAM_USERNAME=
RUSTOPS_STEAM_PASSWORD=
RUSTOPS_STEAM_PERSONA_NAME=Rusticaland Ops
RUSTOPS_STEAM_ADMIN_IDS=
