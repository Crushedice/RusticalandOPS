{
  "api": {
    "baseUrl": "${RUSTOPS_API_BASE_URL}",
    "apiKey": "${RUSTMGR_API_KEY}"
  },
  "monitor": {
    "pollSeconds": 20,
    "controlPollSeconds": 2,
    "logLinesPerScan": 120,
    "healthCooldownMinutes": 10,
    "startupIgnoreSeconds": 180,
    "pluginUpdateCheckMinutes": 180,
    "logRulesPath": "agent-log-rules.json"
  },
  "memory": {
    "statePath": "/opt/rust-manager/agent/RustOpsAgent/data/agent-state.json",
	"neoCortexRoot": "/opt/rust-manager/agent/RustOpsAgent/data/NeoCortex"
  },
  "inbox": {
    "feedbackInboxPath": "${RUSTOPS_FEEDBACK_INBOX_PATH}",
    "decisionInboxPath": "${RUSTOPS_DECISION_INBOX_PATH}",
    "chatInboxPath": "${RUSTOPS_CHAT_INBOX_PATH}"
  },
  "outbox": {
     "messageOutboxPath": "${RUSTOPS_MESSAGE_OUTBOX_PATH}"
  },
  "policy": {
    "allowAnyServerCommand": false,
    "allowedServerCommandPrefixes": [
      "oxide.",
      "o.",
      "status",
      "version",
      "plugins",
      "global.",
      "serverinfo",
      "server."
    ],
    "autoAllowedActions": [
      "validate-oxide",
      "inspect-host-network"
    ],
    "approvalRequiredActions": [
      "restart-server",
      "stop-server",
      "start-server",
      "update-server",
      "wipe-server",
      "write-config",
      "modify-plugin",
      "create-task"
    ]
  },
  "gitOps": {
    "enabled": true,
    "repoPath": "/opt/rust-manager/src",
    "remoteName": "origin",
    "baseBranch": "main",
    "pushBranchPrefix": "agent/",
    "allowPush": true,
    "allowManualPullRebuild": true,
    "autoPullEnabled": false,
    "autoPullIntervalMinutes": 15,
    "autoPullRebuild": true,
    "autoRestartAfterPullRebuild": true,
    "requireCleanWorktreeForPull": true
  },
  "commandExecution": {
    "enabled": true,
    "freeMode": false,
    "defaultWaitMs": 2500,
    "maxWaitMs": 12000,
    "maxOutputChars": 8000,
    "allowList": [
      "playerlist",
      "serverinfo",
      "bans",
      "oxide.plugins",
      "status",
      "version",
      "banlist",
      "mutelist"
    ]
  },
  "pluginUpdates": {
    "enabled": true,
    "checkIntervalMinutes": 60,
    "notifyAdmins": true,
    "searchUrlTemplate": "https://umod.org/plugins/search.json?query={0}&page=1&sort=title&sortdir=asc&filter={1}",
    "searchFilter": "rust"
  },
  "llm": {
    "enabled": true,
    "provider": "${RUSTOPS_LLM_PROVIDER}",
    "baseUrl": "${RUSTOPS_LLM_BASE_URL}",
    "model": "${RUSTOPS_LLM_MODEL}",
    "apiKey": "${RUSTOPS_LLM_API_KEY}",
    "httpReferer": "${RUSTOPS_LLM_HTTP_REFERER}",
    "appTitle": "${RUSTOPS_LLM_APP_TITLE}",
    "useForRecommendations": true,
    "requestStrategy": "${RUSTOPS_LLM_REQUEST_STRATEGY}",
    "secondary": {
      "enabled": true,
      "baseUrl": "${RUSTOPS_LLM_SECONDARY_BASE_URL}",
      "model": "${RUSTOPS_LLM_SECONDARY_MODEL}",
      "apiKey": "${RUSTOPS_LLM_SECONDARY_API_KEY}",
      "httpReferer": "${RUSTOPS_LLM_SECONDARY_HTTP_REFERER}",
      "appTitle": "${RUSTOPS_LLM_SECONDARY_APP_TITLE}"
    },
    "useChatSystemPrompt": true,
    "chatSystemPrompt": "You are a local Rust game-server operations agent talking to a server admin.\nUse the tool results and context provided to answer accurately.\nDo not invent facts — base all answers on the data given.\nFor start, stop, restart, and validate-oxide actions you must target a known server.\nIf the target server is unclear, ask a short clarification question rather than guessing.\nUse recent actions, incidents, and log context to explain what is happening.\nReply in plain, direct operational language — lead with the answer, then supporting evidence.\nKeep replies concise unless critical failure details require more."
  }
}