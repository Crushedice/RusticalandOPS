{
  "api": {
    "baseUrl": "${RUSTOPS_API_BASE_URL}",
    "apiKey": "${RUSTMGR_API_KEY}"
  },
  "monitor": {
    "pollSeconds": 20,
    "controlPollSeconds": 2,
    "logLinesPerScan": 120,
    "healthCooldownMinutes": 10,
    "startupIgnoreSeconds": 180,
    "pluginUpdateCheckMinutes": 180,
    "logRulesPath": "agent-log-rules.json"
  },
  "memory": {
    "statePath": "${RUSTOPS_AGENT_STATE_PATH}",
    "neoCortexRoot": "data/NeoCortex"
  },
  "inbox": {
    "feedbackInboxPath": "${RUSTOPS_FEEDBACK_INBOX_PATH}",
    "decisionInboxPath": "${RUSTOPS_DECISION_INBOX_PATH}",
    "chatInboxPath": "${RUSTOPS_CHAT_INBOX_PATH}",
    "logInboxPath": "${RUSTOPS_LOG_INBOX_PATH}"
  },
  "outbox": {
    "messageOutboxPath": "${RUSTOPS_MESSAGE_OUTBOX_PATH}"
  },
  "policy": {
    "allowAnyServerCommand": false,
    "allowedServerCommandPrefixes": [
      "oxide.",
      "o.",
      "status",
      "version",
      "plugins",
      "global.",
      "serverinfo"
    ],
    "autoAllowedActions": [
      "validate-oxide",
      "inspect-host-network"
    ],
    "approvalRequiredActions": [
      "restart-server",
      "stop-server",
      "start-server",
      "update-server",
      "wipe-server",
      "write-config",
      "modify-plugin",
      "create-task"
    ]
  },
  "commandExecution": {
    "enabled": true,
    "freeMode": false,
    "defaultWaitMs": 2500,
    "maxWaitMs": 12000,
    "maxOutputChars": 8000,
    "allowList": [
      "status",
      "alerts",
      "tickets",
      "devices.list",
      "jobs.list"
    ]
  },
  "integrations": {
    "pollSeconds": 120,
    "maxLogsPerPoll": 200,
    "autotask": {
      "enabled": false,
      "name": "autotask",
      "baseUrl": "${OPS_AUTOTASK_BASE_URL}",
      "integrationCode": "${OPS_AUTOTASK_INTEGRATION_CODE}",
      "username": "${OPS_AUTOTASK_USERNAME}",
      "apiSecret": "${OPS_AUTOTASK_API_SECRET}",
      "accessToken": "${OPS_AUTOTASK_ACCESS_TOKEN}",
      "logsEndpointPath": "/atservicesrest/v1.0/Logs",
      "statusEndpointPath": "/atservicesrest/v1.0/HealthCheck"
    },
    "dattoRmm": {
      "enabled": false,
      "name": "datto-rmm",
      "baseUrl": "${OPS_DATTO_RMM_BASE_URL}",
      "apiKey": "${OPS_DATTO_RMM_API_KEY}",
      "apiSecret": "${OPS_DATTO_RMM_API_SECRET}",
      "accessToken": "${OPS_DATTO_RMM_ACCESS_TOKEN}",
      "logsEndpointPath": "/api/v2/audit/logs",
      "statusEndpointPath": "/api/v2/account"
    }
  },
  "llm": {
    "enabled": true,
    "provider": "${RUSTOPS_LLM_PROVIDER}",
    "baseUrl": "${RUSTOPS_LLM_BASE_URL}",
    "model": "${RUSTOPS_LLM_MODEL}",
    "apiKey": "${RUSTOPS_LLM_API_KEY}",
    "httpReferer": "${RUSTOPS_LLM_HTTP_REFERER}",
    "appTitle": "${RUSTOPS_LLM_APP_TITLE}",
    "useForRecommendations": true,
    "requestStrategy": "fallback",
    "secondary": {
      "enabled": false,
      "baseUrl": "${RUSTOPS_LLM_SECONDARY_BASE_URL}",
      "model": "${RUSTOPS_LLM_SECONDARY_MODEL}",
      "apiKey": "${RUSTOPS_LLM_SECONDARY_API_KEY}",
      "httpReferer": "${RUSTOPS_LLM_SECONDARY_HTTP_REFERER}",
      "appTitle": "${RUSTOPS_LLM_SECONDARY_APP_TITLE}"
    },
    "useChatSystemPrompt": true,
    "chatSystemPrompt": "You are a local operations agent for MSP administrators.\nFocus on connector status, incoming logs, and practical operator actions.\nPrioritize facts from tool output and avoid guessing.\nIf a request is ambiguous, ask a concise clarification question.\nStart responses with the direct outcome, then key evidence and next action."
  }
}
